int displaymenu() {
    int choice;
    cout << "........WELCOME TO THE ONLINE QUIZ PLATFORM........!!!" << endl;
    cout << "....................MAIN MENU..........................." << endl;
    cout << "Select your role (enter 1 or 2)" << endl;
    cout << "1. Teacher" << endl;
